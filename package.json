{
  "name": "twilio-admin",
  "displayName": "Twilio Admin",
  "description": "Manage Twilio subaccounts, phone numbers, and webhooks from VS Code",
  "version": "0.1.0",
  "publisher": "twilio-admin",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomlazelle/vscode_twilio_admin.git"
  },
  "license": "Unlicense",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "node esbuild.extension.mjs",
    "compile:webview": "node esbuild.webview.mjs",
    "compile:all": "node esbuild.extension.mjs && node esbuild.webview.mjs",
    "watch": "concurrently \"node esbuild.extension.mjs --watch\" \"node esbuild.webview.mjs --watch\"",
    "test": "vitest run",
    "test:integration": "vscode-test",
    "lint": "eslint src --ext ts",
    "package": "npm run compile:all && vsce package --no-dependencies"
  },
  "dependencies": {
    "twilio": "^5.7.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^2.27.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.21.5",
    "eslint": "^8.57.0",
    "semantic-release": "^24.0.0",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "twilioAdmin",
          "title": "Twilio Admin",
          "icon": "resources/twilio-admin.svg"
        }
      ]
    },
    "views": {
      "twilioAdmin": [
        {
          "id": "twilioAdmin.accounts",
          "name": "Accounts",
          "type": "tree"
        },
        {
          "id": "twilioAdmin.bookmarks",
          "name": "Bookmarks",
          "type": "tree"
        },
        {
          "id": "twilioAdmin.tags",
          "name": "Tags",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "twilioAdmin.addAccount",
        "title": "Add Account",
        "category": "Twilio Admin"
      },
      {
        "command": "twilioAdmin.editAccount",
        "title": "Edit Account",
        "category": "Twilio Admin"
      },
      {
        "command": "twilioAdmin.deleteAccount",
        "title": "Delete Account",
        "category": "Twilio Admin"
      },
      {
        "command": "twilioAdmin.browseNumbers",
        "title": "Browse Numbers",
        "category": "Twilio Admin"
      },
      {
        "command": "twilioAdmin.addBookmark",
        "title": "Add Bookmark",
        "category": "Twilio Admin"
      },
      {
        "command": "twilioAdmin.openBookmarkDetail",
        "title": "Open Bookmark",
        "category": "Twilio Admin"
      },
      {
        "command": "twilioAdmin.editWebhooks",
        "title": "Edit Webhooks",
        "category": "Twilio Admin"
      },
      {
        "command": "twilioAdmin.refreshCallLogs",
        "title": "Refresh Call Logs",
        "category": "Twilio Admin"
      },
      {
        "command": "twilioAdmin.refreshMessageLogs",
        "title": "Refresh SMS Logs",
        "category": "Twilio Admin"
      },
      {
        "command": "twilioAdmin.playRecording",
        "title": "Play Recording",
        "category": "Twilio Admin"
      },
      {
        "command": "twilioAdmin.lockCredentials",
        "title": "Lock Credentials",
        "category": "Twilio Admin"
      },
      {
        "command": "twilioAdmin.unlockCredentials",
        "title": "Unlock Credentials",
        "category": "Twilio Admin"
      },
      {
        "command": "twilioAdmin.filterByTag",
        "title": "Filter by Tag",
        "category": "Twilio Admin"
      },
      {
        "command": "twilioAdmin.refreshAccounts",
        "title": "Refresh",
        "category": "Twilio Admin",
        "icon": "$(refresh)"
      },
      {
        "command": "twilioAdmin.refreshBookmarks",
        "title": "Refresh",
        "category": "Twilio Admin",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "twilioAdmin.addAccount",
          "when": "view == twilioAdmin.accounts",
          "group": "navigation"
        },
        {
          "command": "twilioAdmin.refreshAccounts",
          "when": "view == twilioAdmin.accounts",
          "group": "navigation"
        },
        {
          "command": "twilioAdmin.refreshBookmarks",
          "when": "view == twilioAdmin.bookmarks",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "twilioAdmin.editAccount",
          "when": "viewItem == account",
          "group": "1_account@1"
        },
        {
          "command": "twilioAdmin.deleteAccount",
          "when": "viewItem == account",
          "group": "1_account@2"
        },
        {
          "command": "twilioAdmin.browseNumbers",
          "when": "viewItem == account",
          "group": "1_account@3"
        },
        {
          "command": "twilioAdmin.editWebhooks",
          "when": "viewItem == bookmark",
          "group": "1_bookmark@1"
        },
        {
          "command": "twilioAdmin.filterByTag",
          "when": "viewItem == tag",
          "group": "1_tag@1"
        }
      ]
    },
    "configuration": {
      "title": "Twilio Admin",
      "properties": {
        "twilioAdmin.logs.pageSize": {
          "type": "number",
          "default": 50,
          "description": "Number of log entries to fetch per request"
        },
        "twilioAdmin.cache.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Cache API responses to disk"
        },
        "twilioAdmin.cache.ttlSeconds": {
          "type": "number",
          "default": 120,
          "description": "Cache time-to-live in seconds"
        },
        "twilioAdmin.security.requireUnlockOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Prompt to unlock credentials when VS Code starts"
        },
        "twilioAdmin.security.passphraseFallbackEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Allow passphrase-derived key when OS keychain is unavailable"
        }
      }
    }
  }
}
